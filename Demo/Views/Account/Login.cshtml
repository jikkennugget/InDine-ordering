@model LoginVM

@{
    ViewBag.Title = "Account | Login";
    Layout = null; // Render login without main layout to avoid header showing logged user
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-container {
            background: linear-gradient(135deg, #fff 0%, #f8fafc 100%);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            padding: 40px;
            width: 100%;
            max-width: 400px;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.8);
        }

        .login-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #d9232e, #f2c300);
        }

        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .login-header h1 {
            color: #1e293b;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 8px;
            border-bottom: 3px solid #e2e8f0;
            padding-bottom: 16px;
            position: relative;
        }

        .login-header h1::after {
            content: '';
            position: absolute;
            bottom: -3px;
            left: 50%;
            transform: translateX(-50%);
            width: 40px;
            height: 3px;
            background: linear-gradient(90deg, #d9232e, #f2c300);
            border-radius: 2px;
        }

        .login-header p {
            color: #64748b;
            font-size: 14px;
            margin-top: 16px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            color: #1e293b;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            font-size: 16px;
            transition: all 0.3s ease;
            background: #fff;
        }

        .form-group input:focus {
            outline: none;
            border-color: #d9232e;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(217, 35, 46, 0.1);
        }

        .form-group input.input-validation-error {
            border-color: #e74c3c;
            background: #fdf2f2;
        }

        .remember-me {
            display: flex;
            align-items: center;
            margin-bottom: 25px;
        }

        .remember-me input[type="checkbox"] {
            width: auto;
            margin-right: 8px;
            transform: scale(1.2);
        }

        .remember-me label {
            margin: 0;
            color: #666;
            font-size: 14px;
            cursor: pointer;
        }

        .button-group {
            display: flex;
            gap: 12px;
            margin-bottom: 25px;
        }

        .btn {
            flex: 1;
            padding: 12px 20px;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary {
            background: linear-gradient(135deg, #d9232e 0%, #b91c2c 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(217, 35, 46, 0.3);
        }
        
        .btn-primary:disabled:hover {
            transform: none !important;
            box-shadow: none !important;
            cursor: not-allowed !important;
        }

        .btn-secondary {
            background: #fff;
            color: #64748b;
            border: 2px solid #e2e8f0;
        }

        .btn-secondary:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

        .links {
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
        }

        .links a {
            color: #d9232e;
            text-decoration: none;
            font-size: 14px;
            margin: 0 10px;
            transition: color 0.3s ease;
        }

        .links a:hover {
            color: #b91c2c;
            text-decoration: underline;
        }

        .validation-summary-errors {
            background: #fdf2f2;
            border: 1px solid #fecaca;
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 20px;
            color: #dc2626;
            font-size: 14px;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 20px;
        }

        .field-validation-error {
            color: #dc2626;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        .security-verification {
            margin: 16px 0;
            display: flex;
            justify-content: center;
        }
        
        .verification-checkbox {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 12px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            background: #f8fafc;
            transition: all 0.3s ease;
        }
        
        .verification-checkbox:hover {
            border-color: #cbd5e1;
            background: #f1f5f9;
        }
        
        .verification-checkbox input[type="checkbox"] {
            width: 18px;
            height: 18px;
            margin: 0;
            transform: scale(1.2);
        }
        
        .verification-checkbox label {
            margin: 0;
            color: #374151;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
        }
        
        .verification-checkbox input[type="checkbox"]:checked + label {
            color: #059669;
            font-weight: 600;
        }
        
        .verification-message {
            text-align: center;
            margin-top: 8px;
            padding: 8px 12px;
            background: #fef3c7;
            border: 1px solid #f59e0b;
            border-radius: 6px;
            transition: all 0.3s ease;
        }
        
        .verification-message.hidden {
            opacity: 0;
            transform: translateY(-10px);
            pointer-events: none;
        }
        
        .verification-text {
            color: #92400e;
            font-size: 13px;
            font-weight: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }
        
        .verification-text::before {
            content: "ℹ️";
            font-size: 14px;
        }

        .input-validation-error {
            border-color: #dc2626 !important;
            background: #fdf2f2 !important;
        }

        @@media (max-width: 480px) {
            .login-container {
                padding: 30px 20px;
                margin: 10px;
            }
            
            .button-group {
                flex-direction: column;
            }
            
            .btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <h1>JikkenRice</h1>
            <p>Sign in to your account</p>
        </div>

        <form method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" type="email" placeholder="Enter your email" autofocus>
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" placeholder="Enter your password">
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <div class="remember-me">
                <input asp-for="RememberMe" type="checkbox" id="RememberMe">
                <label for="RememberMe">Remember me</label>
            </div>

            <div class="form-group">
                <div class="security-verification">
                    <div class="verification-checkbox">
                        <input type="checkbox" id="securityCheck" name="securityCheck">
                        <label for="securityCheck">I am not a robot</label>
                    </div>
                </div>
                <div class="verification-message" id="verification-message">
                    <span class="verification-text">Please check the box above to enable the Sign In button</span>
                </div>
                <span class="field-validation-error" id="hcaptcha-error" style="display: none;">Please complete the security verification.</span>
            </div>

            <div class="button-group">
                <button type="submit" class="btn btn-primary">Sign In</button>
                <a href="/Account/Register" class="btn btn-secondary">Sign Up</a>
            </div>
        </form>

        <div class="links">
            <a href="/Account/ResetPassword">Forgot Password?</a>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
    
    <script>
        let securityCheckCompleted = false;
        
        // Form submission validation
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('form');
            const submitBtn = document.querySelector('button[type="submit"]');
            const securityCheck = document.getElementById('securityCheck');
            const verificationMessage = document.getElementById('verification-message');
            
            // Handle checkbox change
            securityCheck.addEventListener('change', function() {
                securityCheckCompleted = this.checked;
                
                if (securityCheckCompleted) {
                    // Hide error message and verification message when checkbox is checked
                    document.getElementById('hcaptcha-error').style.display = 'none';
                    verificationMessage.classList.add('hidden');
                    
                    // Enable button with success styling
                    submitBtn.disabled = false;
                    submitBtn.style.opacity = '1';
                    submitBtn.style.cursor = 'pointer';
                    submitBtn.style.background = 'linear-gradient(135deg, #059669 0%, #047857 100%)';
                    submitBtn.textContent = 'Sign In ✓';
                    
                    // Add success animation
                    submitBtn.style.transform = 'scale(1.02)';
                    setTimeout(() => {
                        submitBtn.style.transform = 'scale(1)';
                    }, 200);
                } else {
                    // Show verification message and disable button when unchecked
                    verificationMessage.classList.remove('hidden');
                    submitBtn.disabled = true;
                    submitBtn.style.opacity = '0.6';
                    submitBtn.style.cursor = 'not-allowed';
                    submitBtn.style.background = 'linear-gradient(135deg, #d9232e 0%, #b91c2c 100%)';
                    submitBtn.textContent = 'Sign In';
                }
            });
            
            form.addEventListener('submit', function(e) {
                if (!securityCheckCompleted) {
                    e.preventDefault();
                    document.getElementById('hcaptcha-error').style.display = 'block';
                    
                    // Scroll to security verification
                    document.querySelector('.security-verification').scrollIntoView({ 
                        behavior: 'smooth', 
                        block: 'center' 
                    });
                    
                    // Add visual feedback
                    const verificationContainer = document.querySelector('.verification-checkbox');
                    verificationContainer.style.border = '2px solid #dc2626';
                    verificationContainer.style.background = '#fdf2f2';
                    
                    setTimeout(() => {
                        verificationContainer.style.border = '';
                        verificationContainer.style.background = '';
                    }, 3000);
                    
                    return false;
                }
            });
            
            // Disable submit button initially
            submitBtn.disabled = true;
            submitBtn.style.opacity = '0.6';
            submitBtn.style.cursor = 'not-allowed';
        });
    </script>
</body>
</html>
