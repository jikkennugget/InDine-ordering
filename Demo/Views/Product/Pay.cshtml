@model Order

@{
    ViewBag.Title = $"Pay Order #{Model.Id}";
    var total = Model.OrderLines.Sum(ol => ol.Price * ol.Quantity);
}

@section head {
    <style>
        .payment-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px;
        }

        .payment-header {
            background: linear-gradient(135deg, #fff 0%, #f8fafc 100%);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            padding: 30px;
            margin-bottom: 30px;
            border: 1px solid rgba(255, 255, 255, 0.8);
            position: relative;
            overflow: hidden;
        }

        .payment-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #d9232e, #f2c300);
        }

        .payment-title {
            color: #1e293b;
            font-size: 28px;
            font-weight: 700;
            margin: 0 0 20px 0;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .payment-title::before {
            content: '💳';
            font-size: 32px;
        }

        .order-info {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .info-item {
            display: flex;
            flex-direction: column;
        }

        .info-label {
            color: #64748b;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .info-value {
            color: #1e293b;
            font-size: 16px;
            font-weight: 600;
        }

        .payment-content {
            display: grid;
            grid-template-columns: 1fr 450px;
            gap: 30px;
            align-items: start;
        }

        .order-items {
            background: linear-gradient(135deg, #fff 0%, #f8fafc 100%);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            padding: 30px;
            border: 1px solid rgba(255, 255, 255, 0.8);
        }

        .order-items h3 {
            color: #1e293b;
            font-size: 20px;
            font-weight: 700;
            margin: 0 0 20px 0;
            border-bottom: 3px solid #e2e8f0;
            padding-bottom: 16px;
            position: relative;
        }

        .order-items h3::after {
            content: '';
            position: absolute;
            bottom: -3px;
            left: 0;
            width: 40px;
            height: 3px;
            background: linear-gradient(90deg, #d9232e, #f2c300);
            border-radius: 2px;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        .items-table th {
            background: #d9232e;
            color: white;
            padding: 16px 12px;
            text-align: left;
            font-weight: 600;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .items-table th:last-child {
            text-align: right;
        }

        .items-table td {
            padding: 16px 12px;
            border-bottom: 1px solid #e2e8f0;
            color: #1e293b;
            font-weight: 500;
        }

        .items-table td:last-child {
            text-align: right;
            font-weight: 600;
            color: #d9232e;
        }

        .items-table tr:last-child td {
            border-bottom: none;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            font-weight: 700;
            font-size: 16px;
            color: #1e293b;
        }

        .payment-section {
            background: linear-gradient(135deg, #fff 0%, #f8fafc 100%);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            padding: 30px;
            border: 3px solid #d9232e;
            position: sticky;
            top: 20px;
            position: relative;
            overflow: hidden;
        }

        .payment-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, #d9232e, #f2c300);
        }

        .payment-section::after {
            content: '💳 PAY HERE';
            position: absolute;
            top: 15px;
            right: 20px;
            background: linear-gradient(135deg, #d9232e 0%, #b91c2c 100%);
            color: white;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            box-shadow: 0 2px 8px rgba(217, 35, 46, 0.3);
        }

        .payment-section h3 {
            color: #d9232e;
            font-size: 24px;
            font-weight: 700;
            margin: 0 0 20px 0;
            border-bottom: 3px solid #e2e8f0;
            padding-bottom: 16px;
            position: relative;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .payment-section h3::before {
            content: '💳';
            font-size: 28px;
        }

        .payment-section h3::after {
            content: '';
            position: absolute;
            bottom: -3px;
            left: 0;
            width: 40px;
            height: 3px;
            background: linear-gradient(90deg, #d9232e, #f2c300);
            border-radius: 2px;
        }

        .total-amount-display {
            background: linear-gradient(135deg, #d9232e 0%, #b91c2c 100%);
            color: white;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            margin-bottom: 25px;
            box-shadow: 0 4px 15px rgba(217, 35, 46, 0.3);
        }

        .total-label {
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
            opacity: 0.9;
        }

        .total-value {
            font-size: 32px;
            font-weight: 700;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            color: #374151;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .form-group select {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-size: 16px;
            background: white;
            color: #1e293b;
            transition: all 0.2s ease;
        }

        .form-group select:focus {
            outline: none;
            border-color: #d9232e;
            box-shadow: 0 0 0 3px rgba(217, 35, 46, 0.1);
        }

        .qr-section {
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            padding: 24px;
            text-align: center;
            margin-top: 20px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .qr-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #ff6b9d, #c44569, #f8b500);
        }

        .qr-section p {
            color: #1e293b;
            font-weight: 700;
            margin-bottom: 20px;
            font-size: 16px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .qr-section img {
            transition: transform 0.3s ease;
        }

        .qr-section img:hover {
            transform: scale(1.05);
        }

        .button-group {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }

        .btn {
            flex: 1;
            padding: 14px 20px;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            text-align: center;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #d9232e 0%, #b91c2c 100%);
            color: white;
            font-size: 18px;
            font-weight: 700;
            padding: 16px 24px;
            box-shadow: 0 4px 15px rgba(217, 35, 46, 0.3);
            border: 2px solid #d9232e;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(217, 35, 46, 0.4);
            background: linear-gradient(135deg, #b91c2c 0%, #991b1b 100%);
        }

        .btn-secondary {
            background: linear-gradient(135deg, #64748b 0%, #475569 100%);
            color: white;
        }

        .btn-secondary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(100, 116, 139, 0.3);
        }

        .payment-section {
            animation: pulse-glow 2s ease-in-out infinite alternate;
        }

        @@keyframes pulse-glow {
            from {
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1), 0 0 0 0 rgba(217, 35, 46, 0.4);
            }
            to {
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1), 0 0 0 10px rgba(217, 35, 46, 0);
            }
        }

        @@media (max-width: 768px) {
            .payment-container {
                padding: 10px;
            }
            
            .payment-content {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            
            .payment-header, .order-items, .payment-section {
                padding: 20px;
            }
            
            .order-info {
                grid-template-columns: 1fr;
                gap: 16px;
            }
            
            .button-group {
                flex-direction: column;
            }
        }
    </style>
}

<div class="payment-container">
    <div class="payment-header">
        <h1 class="payment-title">Pay Order #@Model.Id</h1>
        
        <div class="order-info">
            <div class="info-item">
                <span class="info-label">Order Number</span>
                <span class="info-value">#@Model.Id</span>
            </div>
            <div class="info-item">
                <span class="info-label">Table Number</span>
                <span class="info-value">@Model.TableNumber</span>
            </div>
            <div class="info-item">
                <span class="info-label">Order Date</span>
                <span class="info-value">@Model.Date.ToString("MMM dd, yyyy")</span>
            </div>
        </div>
    </div>

    <div class="payment-content">
        <div class="order-items">
            <h3>Order Items</h3>
            
            <table class="items-table">
                <thead>
        <tr>
            <th>Item</th>
                        <th>Qty</th>
                        <th>Price</th>
                        <th>Subtotal</th>
        </tr>
                </thead>
                <tbody>
        @foreach (var ol in Model.OrderLines)
        {
            <tr>
                <td>@ol.Product.Name</td>
                            <td>@ol.Quantity</td>
                            <td>RM @ol.Price.ToString("F2")</td>
                            <td>RM @((ol.Price * ol.Quantity).ToString("F2"))</td>
            </tr>
        }
        <tr>
                        <td colspan="3"><strong>Total</strong></td>
                        <td><strong>RM @total.ToString("F2")</strong></td>
        </tr>
                </tbody>
    </table>
        </div>

        <div class="payment-section">
            <h3>Payment</h3>
            
            <div class="total-amount-display">
                <div class="total-label">Total Amount</div>
                <div class="total-value">RM @total.ToString("F2")</div>
            </div>
            
            <form method="post" action="/Product/Pay/@Model.Id">
                <div class="form-group">
                    <label for="method">Payment Method</label>
                    <select name="method" id="method" required>
                        <option value="Cash">💵 Cash</option>
                        <option value="QRPay">📱 QR Pay</option>
                        <option value="CreditCard">💳 Credit Card</option>
            </select>
        </div>
                
                <div id="qr" class="qr-section" style="display:none;">
                    <p>Scan DuitNow QR code to pay</p>
                    <img src="/images/duitnow-qr.png" alt="DuitNow QR Code - JIKKENNUGGET MUSIC" style="width: 200px; height: 200px; object-fit: contain; border-radius: 12px; border: 3px solid #fff; box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);">
                </div>
                
                <div class="button-group">
                    <button type="submit" class="btn btn-primary">
                        💳 PAY NOW
                    </button>
                    <a href="/Product/Order" class="btn btn-secondary">
                        ← Back to Orders
                    </a>
                </div>
            </form>
        </div>
        </div>
</div>

@section foot {
    <script>
        $(function(){
            $('select[name=method]').on('change', function(){
                const v = $(this).val();
                if(v === 'QRPay') $('#qr').slideDown(120); else $('#qr').slideUp(120);
            }).trigger('change');
        });
    </script>
}


